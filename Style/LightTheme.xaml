<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Style/Generic.xaml"/>
        
    </ResourceDictionary.MergedDictionaries>
    <SolidColorBrush  x:Key="BackgroundColor" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="LoginForegroundColor" Color="#333333"/>
    <SolidColorBrush x:Key="BorderBrushColor" Color="#EAEAEA"/>
    <SolidColorBrush x:Key="MenuBackgroundColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="MenuForegroundColor" Color="#666666"/>
    <LinearGradientBrush x:Key="LeftMenuBackgroundColor">
        <LinearGradientBrush.GradientStops>
            <GradientStop Color="#28B25C" Offset="0"/>
            <GradientStop Color="#2494BE" Offset="1"/>
        </LinearGradientBrush.GradientStops>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="MenuMouseOverBackgroundColor" Color="#E1F4E8"/>
    <SolidColorBrush x:Key="IndexTextForegroundColor" Color="#333333"/>
    <SolidColorBrush x:Key="IndexCardBackgroundColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="IndexCardForegroundColor" Color="#333333"/>
    
    <!--图片-->
    <Image x:Key="代办事项" Source="/Image/首页卡片/待办事项.png" Width="56" Height="60"/>
</ResourceDictionary>