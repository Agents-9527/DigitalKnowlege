<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:知识产权数字化平台.Views" 
             xmlns:prism="http://prismlibrary.com/"
             xmlns:ni="http://schemas.ni.com/controls/2009/xaml/presentation" 
             x:Class="知识产权数字化平台.Views.LoginView"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="1080" d:DesignWidth="1920">
    <UserControl.Background>
        <ImageBrush ImageSource="/Image/登录界面/登录背景.png" />
    </UserControl.Background>
    <Canvas>
        <StackPanel Orientation="Horizontal" Background="Transparent" WindowChrome.IsHitTestVisibleInChrome="True"
               Canvas.Left="360" Canvas.Top="160">

            <Image Source="/Image/登录界面/Aero_Engine.png" Width="500"/>

        </StackPanel>
        <Grid Canvas.Left="360" Canvas.Top="288" Width="636">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <Border Width="4" Height="26" Background="{DynamicResource GenericBlueColor}"/>
                <TextBlock Text="强度传动试验解决方案，赋能强度传动试验" Margin="8 0" FontWeight="Bold" FontSize="28" Foreground="{DynamicResource LoginForegroundColor}"/>
            </StackPanel>
            <TextBlock Grid.Row="1" Margin="0 10" TextWrapping="Wrap" Text="将试验测试、试验控制、数据保存、数据分析等核心业务场景充分融合到平台，全面提升试验效率。"/>
            <Image Grid.Row="2" Margin="10 0" Source="/Image/登录界面/登录人物.png" Width="332" Height="297"/>
        </Grid>
        <!--login 框-->
        <Border Width="390" Height="484" Background="White" Canvas.Left="1170" Canvas.Top="288" CornerRadius="5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="Black" Opacity="0.15"/>
            </Border.Effect>
            <StackPanel>
                <StackPanel Margin="0 37 0 0" HorizontalAlignment="Center">
                    <TextBlock Text="账号登录" FontSize="28" Margin="8 0" FontWeight="Bold" Foreground="{DynamicResource LoginForegroundColor}"/>
                </StackPanel>
                <StackPanel Margin="0 35 0 0" HorizontalAlignment="Center">
                    <TextBox Style="{DynamicResource TextBoxUserNameStyle}"
                             Text="{Binding UserName,UpdateSourceTrigger=PropertyChanged}"
                             />
                </StackPanel>
                <StackPanel Margin="0 35 0 0" HorizontalAlignment="Center">
                    <TextBox Style="{DynamicResource TextBoxPasswordStyle}"
                             Text="{Binding Password,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Margin="0 25 0 0">
                    <Grid Margin="26 0">
                        <CheckBox Style="{DynamicResource CheckBoxStyle}" Content="记住密码" Foreground="{DynamicResource GenericLightGrayColor}" HorizontalAlignment="Left"/>
                        <TextBlock Text="忘记(找回)密码" Foreground="{DynamicResource GenericLightGrayColor}" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
                <!-- 登录状态提示（新增） -->
                <StackPanel Margin="0 0 0 0" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TipText}" Height="20" Width="300" Background="Transparent" Foreground="Red" FontSize="14"/>
                </StackPanel>
                <StackPanel Margin="0 20 0 0" HorizontalAlignment="Center">
                    <Button Style="{DynamicResource ButtonLoginStyle}" 
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsLoginButtonEnabled}"
                    Content="登录" />
                </StackPanel>
                <StackPanel Margin="0 20 0 0" HorizontalAlignment="Center">
                    <Button Style="{DynamicResource ButtonRegisterStyle}"
                    Content="注册" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Canvas>
</UserControl>
