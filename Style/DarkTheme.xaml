<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        
        <ResourceDictionary Source="/Style/Generic.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    <SolidColorBrush  x:Key="DarkColor" Color="#1A1D23"/>
    <SolidColorBrush x:Key="LoginForegroundColor" Color="#333333"/>
    <SolidColorBrush x:Key="BorderBrushColor" Color="#484D57"/>
    <SolidColorBrush x:Key="MenuBackgroundColor" Color="#22262F"/>
    <SolidColorBrush x:Key="MenuForegroundColor" Color="#FFFFFF"/>
    <LinearGradientBrush x:Key="LeftMenuBackgroundColor">
        <LinearGradientBrush.GradientStops>
            <GradientStop Color="#333944" Offset="0"/>
            <GradientStop Color="#1E212A" Offset="1"/>
        </LinearGradientBrush.GradientStops>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="MenuMouseOverBackgroundColor" Color="#282A2E"/>
    <SolidColorBrush x:Key="IndexTextForegroundColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="IndexCardBackgroundColor" Color="#333944"/>
    <SolidColorBrush x:Key="IndexCardForegroundColor" Color="#FFFFFF"/>
</ResourceDictionary>